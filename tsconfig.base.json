{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "paths": {
      "@carboti/ai-advisory": ["./packages/ai-advisory/src/index.ts"],
      "@carboti/audit": ["./packages/audit/src/index.ts"],
      "@carboti/auth": ["./packages/auth/src/index.ts"],
      "@carboti/charts": ["./packages/charts/src/index.tsx"],
      "@carboti/config": ["./packages/config/src/index.ts"],
      "@carboti/core": ["./packages/core/src/index.ts"],
      "@carboti/db": ["./packages/db/src/index.ts"],
      "@carboti/design-system": ["./packages/design-system/src/index.ts"],
      "@carboti/email": ["./packages/email/src/index.ts"],
      "@carboti/files": ["./packages/files/src/index.ts"],
      "@carboti/i18n": ["./packages/i18n/src/index.ts"],
      "@carboti/import-pipeline": ["./packages/import-pipeline/src/index.ts"],
      "@carboti/jobs": ["./packages/jobs/src/index.ts"],
      "@carboti/rbac": ["./packages/rbac/src/index.ts"],
      "@carboti/testing": ["./packages/testing/src/index.ts"],
      "@carboti/ui": ["./packages/ui/src/index.ts"],
      "@/components": ["./packages/ui/src"],
      "@/components/*": ["./packages/ui/src/*"],
      "@/components/ui": ["./packages/ui/src"],
      "@/components/ui/*": ["./packages/ui/src/*"],
      "@/hooks": ["./packages/ui/src/hooks"],
      "@/hooks/*": ["./packages/ui/src/hooks/*"],
      "@/lib": ["./packages/ui/src"],
      "@/lib/*": ["./packages/ui/src/*"],
      "@/lib/utils": ["./packages/ui/src/utils.ts"],
      "@carboti/example-import-review": ["./examples/import-review/src/index.ts"],
      "@carboti/example-json-records": ["./examples/json-records/src/index.ts"]
    }
  }
}
